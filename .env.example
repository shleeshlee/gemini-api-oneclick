# Basic
TZ=UTC
IMAGE_NAME=gemini-api-oneclick:local
START_PORT=8001
CONTAINER_PREFIX=gemini_api_account_
API_KEY=

# Optional outbound proxy
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1

# Cookie Manager
COOKIE_MANAGER_PORT=9880
COOKIE_MANAGER_PASSWORD=change_me

# Channel guard (newapi integration)
ENABLE_CHANNEL_GUARD=false
GUARD_ERROR_THRESHOLD=3
GUARD_LOG_WINDOW_SECONDS=300
GUARD_NEWAPI_CONTAINER=newapi-new-api-1
GUARD_NEWAPI_MYSQL_CONTAINER=newapi-mysql-1
NEWAPI_DB_NAME=new-api
NEWAPI_DB_USER=root
NEWAPI_DB_PASS=change_me
# Auto-disable switch: false = log only, don't actually disable channels
GUARD_AUTO_DISABLE=true
# Status code whitelist: only these codes trigger disable (comma-separated, e.g. 503)
# Leave empty to not match by status code
GUARD_DISABLE_CODES=
# Keyword whitelist: only errors containing these keywords trigger disable (comma-separated)
# Leave empty to disable all auto-disable (log only)
GUARD_DISABLE_KEYWORDS=credentials not configured,failed to initialize
